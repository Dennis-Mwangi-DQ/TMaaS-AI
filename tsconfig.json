{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/report/reportGenerator.js"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}